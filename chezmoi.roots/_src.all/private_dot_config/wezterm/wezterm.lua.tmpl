-- =============================================================================
-- Native SSH Launcher Integration
-- This section adds SSH hosts from ssh_config to the launcher using the native
-- system SSH binary instead of WezTerm's built-in SSH. This allows features
-- like DynamicForward, LocalCommand, RemoteCommand, etc. to work properly.
-- Comment out ENABLE_NATIVE_SSH_LAUNCHER = true to disable this feature.
-- =============================================================================
local ENABLE_NATIVE_SSH_LAUNCHER = true

if ENABLE_NATIVE_SSH_LAUNCHER then
    -- Helper function to check if a command exists on PATH (uses wezterm API to avoid visible windows)
    local function command_exists(cmd)
        {{ if eq .chezmoi.os "windows" -}}
        local success, stdout, stderr = wezterm.run_child_process({"cmd.exe", "/c", "where", cmd})
        {{ else -}}
        local success, stdout, stderr = wezterm.run_child_process({"sh", "-c", "command -v " .. cmd})
        {{- end }}
        return success and stdout and stdout ~= ""
    end

    -- Helper function to check if a file exists
    local function file_exists(path)
        local f = io.open(path, "r")
        if f then
            f:close()
            return true
        end
        return false
    end

    -- Hardcoded paths for SSH wrapper scripts
    local home = wezterm.home_dir
    local connect_ssh_path = home .. "/.config/sz.env/pwsh/Scripts/base.win/Connect-SSH.cmd"
    local safe_ssh_path = home .. "/.config/sz.env/pwsh/Scripts/base/safe-ssh.cmd"

    -- Determine the SSH binary: prefer connect-ssh or safe-ssh if available
    local ssh_binary
    if command_exists("connect-ssh") then
        ssh_binary = "connect-ssh"
    elseif file_exists(connect_ssh_path) then
        ssh_binary = connect_ssh_path
    elseif command_exists("safe-ssh") then
        ssh_binary = "safe-ssh"
    elseif file_exists(safe_ssh_path) then
        ssh_binary = safe_ssh_path
    else
        {{ if eq .chezmoi.os "windows" -}}
        ssh_binary = "ssh.exe"
        {{ else -}}
        ssh_binary = "ssh"
        {{- end }}
    end

    -- Build the launch menu
    config.launch_menu = config.launch_menu or {}

    -- =========================================================================
    -- PART 1: Add local and WSL domains FIRST (before SSH entries)
    -- =========================================================================
    
    -- Add local domain entry
    table.insert(config.launch_menu, {
        label = "New Tab (local)",
        domain = { DomainName = "local" },
    })

    -- Add WSL domains (Windows only)
    {{ if eq .chezmoi.os "windows" -}}
    local wsl_domains = wezterm.default_wsl_domains()
    for _, wsl in ipairs(wsl_domains) do
        table.insert(config.launch_menu, {
            label = "New Tab (" .. wsl.name .. ")",
            domain = { DomainName = wsl.name },
        })
    end
    {{- end }}

    -- =========================================================================
    -- PART 2: Build SSH entries as a tree structure
    -- =========================================================================
    
    -- Add a legend/separator line explaining the symbols
    table.insert(config.launch_menu, {
        label = "--- SSH: L=LocalFwd D=DynamicFwd J=JumpHost R=RemoteCmd ---",
        -- This is just a legend - selecting it opens a local shell
        domain = { DomainName = "local" },
    })

    -- Get host configs for hostname lookup
    local ssh_hosts = wezterm.enumerate_ssh_hosts()

    -- Collect SSH hosts from the cached domains (preserves WezTerm's original ordering)
    -- We do NOT sort - the tree algorithm preserves order at each level
    local hosts_list = {}
    for _, domain in ipairs(default_ssh_domains_cache) do
        local host = domain.name:match("^SSH:(.+)$")
        if host and not host:match("[*?]") then
            table.insert(hosts_list, host)
        end
    end

    -- Helper function to find common prefix (parent) of a host
    local function get_parent(host)
        -- Find the last dot and return everything before it
        local last_dot = host:match(".*()%.")
        if last_dot then
            return host:sub(1, last_dot - 1)
        end
        return nil
    end

    -- Helper function to get the suffix after the parent
    local function get_suffix(host, parent)
        if parent then
            return host:sub(#parent + 2) -- +2 to skip the dot
        end
        return host
    end

    -- Build a set of all hosts for quick lookup
    local hosts_set = {}
    for _, host in ipairs(hosts_list) do
        hosts_set[host] = true
    end

    -- Symbols for SSH config features (single ASCII chars for consistent width)
    -- Using letters that are easy to remember: L=Local/static, D=Dynamic, J=Jump, R=Remote
    local SYM_STATIC_TUNNEL = "L"   -- LocalForward/RemoteForward
    local SYM_DYNAMIC_TUNNEL = "D"  -- DynamicForward (SOCKS proxy)
    local SYM_JUMPHOST = "J"        -- ProxyJump/ProxyCommand
    local SYM_REMOTE_CMD = "R"      -- RemoteCommand
    local SYM_NONE = " "            -- Placeholder dot for alignment (ASCII period)

    -- Helper to detect SSH config features
    local function get_host_symbols(host_config)
        if not host_config then
            return SYM_NONE, SYM_NONE, SYM_NONE, SYM_NONE
        end

        local static = SYM_NONE
        local dynamic = SYM_NONE
        local jump = SYM_NONE
        local remote = SYM_NONE

        -- Check for static tunnels (LocalForward or RemoteForward)
        if host_config.localforward or host_config.remoteforward then
            static = SYM_STATIC_TUNNEL
        end

        -- Check for dynamic tunnel (DynamicForward / SOCKS proxy)
        if host_config.dynamicforward then
            dynamic = SYM_DYNAMIC_TUNNEL
        end

        -- Check for jumphost (ProxyJump or ProxyCommand)
        if host_config.proxyjump or host_config.proxycommand then
            jump = SYM_JUMPHOST
        end

        -- Check for remote command
        if host_config.remotecommand then
            remote = SYM_REMOTE_CMD
        end

        return static, dynamic, jump, remote
    end

    -- Track which hosts have been added (to avoid duplicates)
    local added_hosts = {}

    -- First pass: collect all entries to calculate max width for alignment
    local entries = {}

    local function collect_entries(host, depth)
        if added_hosts[host] then return end
        added_hosts[host] = true

        local host_config = ssh_hosts[host]
        local indent = string.rep("  ", depth)
        local name_part

        if depth == 0 then
            name_part = host
        else
            local suffix = get_suffix(host, get_parent(host))
            name_part = indent .. "\\." .. suffix
        end

        local hostname_info = ""
        if host_config and host_config.hostname and host_config.hostname ~= host then
            hostname_info = host_config.hostname
        end

        local s_static, s_dynamic, s_jump, s_remote = get_host_symbols(host_config)

        table.insert(entries, {
            host = host,
            name_part = name_part,
            hostname_info = hostname_info,
            sym_static = s_static,
            sym_dynamic = s_dynamic,
            sym_jump = s_jump,
            sym_remote = s_remote,
        })

        -- Find and collect children (hosts that have this host as parent)
        for _, child in ipairs(hosts_list) do
            if get_parent(child) == host and not added_hosts[child] then
                collect_entries(child, depth + 1)
            end
        end
    end

    -- Collect all root-level hosts and their children
    for _, host in ipairs(hosts_list) do
        local parent = get_parent(host)
        if not parent or not hosts_set[parent] then
            collect_entries(host, 0)
        end
    end

    -- Calculate max widths for alignment
    local max_name_width = 0
    local max_hostname_width = 0
    for _, entry in ipairs(entries) do
        if #entry.name_part > max_name_width then
            max_name_width = #entry.name_part
        end
        if #entry.hostname_info > max_hostname_width then
            max_hostname_width = #entry.hostname_info
        end
    end

    -- Second pass: build labels with aligned columns
    -- Format: "SSH: {name}{pad1} {sym1}{sym2}{sym3}{sym4} ({hostname}{pad2})"
    for _, entry in ipairs(entries) do
        -- Pad name to align symbol column
        local name_padding = string.rep(" ", max_name_width - #entry.name_part)
        
        -- Build symbols column: [static][dynamic][jump][remote] - always 4 chars
        local symbols = entry.sym_static .. entry.sym_dynamic .. entry.sym_jump .. entry.sym_remote

        -- Pad hostname inside brackets to align closing brackets
        local hostname_display = entry.hostname_info
        if hostname_display == "" then
            -- Empty placeholder to maintain bracket alignment
            hostname_display = string.rep(" ", max_hostname_width)
        else
            -- Pad hostname to align closing brackets
            hostname_display = hostname_display .. string.rep(" ", max_hostname_width - #entry.hostname_info)
        end

        -- Build the label with all columns aligned
        local label = "SSH: " .. entry.name_part .. name_padding .. " " .. symbols .. " (" .. hostname_display .. ")"

        table.insert(config.launch_menu, {
            label = label,
            args = { ssh_binary, entry.host },
            domain = { DomainName = "local" },
            set_environment_variables = {
                SSH_HOST = entry.host,
            },
        })
    end

    -- Keep tabs open when SSH exits with error (for debugging)
    -- Change to "Close" to always close, or "CloseOnCleanExit" to close only on success
    config.exit_behavior = "Hold"

    wezterm.log_info("Native SSH Launcher: Loaded " .. #config.launch_menu .. " entries")
end
-- =============================================================================
-- End of Native SSH Launcher Integration
-- =============================================================================

-- =============================================================================
-- Custom Tab Title: Show SSH host name instead of process name
-- =============================================================================
wezterm.on("format-tab-title", function(tab, tabs, panes, cfg, hover, max_width)
    local pane = tab.active_pane
    local title = nil

    -- First, check for SSH_HOST user var (set by Connect-SSH.cmd or safe-ssh via OSC 1337)
    if pane.user_vars and pane.user_vars.SSH_HOST then
        title = pane.user_vars.SSH_HOST
    end

    -- If no user var, try to extract from pane title
    if not title then
        local pane_title = pane.title or ""
        -- Pattern: user@host at start
        title = pane_title:match("^(%S+@%S+)")
        -- Pattern: "ssh host" or "Connect-SSH host"
        title = title or pane_title:match("[/\\]?[Ss][Ss][Hh][%.exemd]*%s+(%S+)$")
        title = title or pane_title:match("[Cc]onnect%-[Ss][Ss][Hh][%.cmd]*%s+(%S+)")
        -- Pattern: hostname with dots (no spaces)
        if not title and not pane_title:match("%s") and pane_title:match("%.") then
            title = pane_title
        end
    end

    -- Fall back to process name
    if not title or title == "" then
        local process_name = pane.foreground_process_name or ""
        title = process_name:match("([^/\\]+)$") or pane.title or "?"
    end

    -- Truncate if needed
    if #title > max_width then
        title = wezterm.truncate_right(title, max_width - 1) .. "…"
    end

    return title
end)

-- and finally, return the configuration to wezterm
return config

