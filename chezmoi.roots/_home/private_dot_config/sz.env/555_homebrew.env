#!/usr/bin/env -S bash -c 'echo "Not a user script. source(aka .) only"'

! [ -x /opt/homebrew/bin/brew ] || \
    eval "$(/opt/homebrew/bin/brew shellenv)"
! [ -x /home/linuxbrew/.linuxbrew/Homebrew/bin/brew ] || \
    eval "$(/home/linuxbrew/.linuxbrew/Homebrew/bin/brew shellenv | sed -Ee 's|/var/home|/home|g;')"

