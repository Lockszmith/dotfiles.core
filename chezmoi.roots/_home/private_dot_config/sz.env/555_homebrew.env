#!/usr/bin/env -S bash -c 'echo "Not a user script. source(aka .) only"'

HOMEBREW_PREFIX=${HOMEBREW_PREFIX:-/opt/homebrew/bin}
[ -x "$HOMEBREW_PREFIX"/brew ] || HOMEBREW_PREFIX=/var/home/linuxbrew/.linuxbrew/Homebrew/bin
[ -x "$HOMEBREW_PREFIX"/brew ] || HOMEBREW_PREFIX=/home/linuxbrew/.linuxbrew/Homebrew/bin
[ -x "$HOMEBREW_PREFIX"/brew ] || unset HOMEBREW_PREFIX

[ -z "$HOMEBREW_PREFIX" ] || eval "$($HOMEBREW_PREFIX/brew shellenv)"

