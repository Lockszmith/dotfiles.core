#!/usr/bin/env -S bash -c 'echo "Not a user script. source(aka .) only"'

[ -z "${DBG}" ] || set -vx

if [[ ! "$-" =~ i ]]; then
    LOAD_EXIT=1
    echo "Non interactive session ($-) , stopping load of shell environment" 1>&2
else
    [ -z "$UMASK" ] || umask "$UMASK"
    
    match-terminfo() {
        local TOE
        if is_cmd toe; then
            TOE="$(toe -a | grep -E '^(xterm|vt100|dumb)' | awk '{ print $1 }')"
        fi
        if [ -z "${TOE}" ]; then
            TOE="$(
                find_in \
                    "$TERMINFO:$TERMINFO_DIRS:::/etc/terminfo:/lib/terminfo:/usr/share/terminfo:/run/host/usr/share/terminfo:" \
                    ${1:+-name} ${1:+$1} ${1:+-or} \
                    -name 'xterm*' -or \
                    -name 'vt100*' -or \
                    -name 'dumb'
            )"
        fi
        <<<"${TOE}" xargs -rn1 basename \
        | grep -E '^(xterm|vt100|dumb)' | sed -Ee '
            s/^(.*)$/9 \1/g;
            '"$(
                [ -z "${1## }" ] || printf 's/^9 (%s)$/1 \\1/; ' "$1"
            )"'
            s/^9 (xterm-256color)/2 \1/;
            s/^9 (xterm)$/3 \1/;
            s/^9 (xterm\+256color)/4 \1/;
            s/^9 (vt100-putty)$/5 \1/;
            s/^9 (vt100)$/6 \1/;
            s/^9 (dumb)/8 \1/;
        ' | sort | head -n${2:-1} | awk '{ print $2 }'
    }
    BEST_TERM="$(match-terminfo "${TERM## }")"
    [ "$BEST_TERM" = "$TERM" ] || export TERM="$BEST_TERM" && unset BEST_TERM

    ${NO_RESET:+:} reset
    export NO_RESET=1

    if [ -z "$LANG" ] && is_cmd locale; then
        export LANG="$(locale -a | grep -Ei '^(en_US|C|POSIX)(\.utf-8)?$' | head -n1)"
    fi
    set +x
fi

[ -z "${DBG}" ] || set +vx

# vim: set ft=sh expandtab tabstop=4 shiftwidth=4:
