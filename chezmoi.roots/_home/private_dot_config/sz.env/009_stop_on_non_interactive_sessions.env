#!/usr/bin/env -S bash -c 'echo "Not a user script. source(aka .) only"'


[ -z "${DBG}" ] || set -vx

if [[ ! "$-" =~ i ]]; then
    LOAD_EXIT=1
    echo "Non interactive session ($-) , stopping load of shell environment" 1>&2
else
    [ -z "$UMASK" ] || umask "$UMASK"
    if [ -z "$TERM" ] || ! [ -r "/usr/share/terminfo/$TERM" ]; then 
        TERM="$(find /usr/share/terminfo -type f -print0 | xargs -0n1 basename \
            | grep -E '^(xterm|vt100|dumb)' | sed -Ee '
                s/^(.*)$/9 \1/g;
                s/^9 (xterm-256color)/1 \1/;
                s/^9 (xterm)$/2 \1/;
                s/^9 (vt100-putty)$/3 \1/;
                s/^9 (vt100)$/4 \1/;
                s/^9 (dumb)/8 \1/;
            ' | sort | head -n1 | awk '{ print $2 }'
        )"
    fi
    if [ -z "$LANG" ] && is_cmd locale; then
        export LANG="$(locale -a | grep -Ei '^(en_US|C|POSIX)(\.utf-8)?$' | head -n1)"
    fi

    export TERM
    ${NO_RESET:+:} reset
    export NO_RESET=1
fi

[ -z "${DBG}" ] || set +vx

# vim: set ft=sh expandtab tabstop=4 shiftwidth=4:
