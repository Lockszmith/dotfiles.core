#!/usr/bin/env -S sh -c 'echo "Not a user script. source(aka .) only"'

# Remove duplicates from PATH
unique_list(){
    # POSIX awk-only solution: unique values (first-occurrence order),
    # collapses consecutive/leading/trailing delimiters, skips empties.
    # Delimiter from $D (env var, default ":"). Outputs to stdout (no trailing \n).
    local D="${D:-:}"
    awk -v delim="$D" '
        BEGIN {
            FS = delim
        }
        NR == 1 {
            for (i = 1; i <= NF; i++) {
                field = $i
                # Optional: trim whitespace (POSIX gsub)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", field)
                if (field != "" && !(field in seen)) {
                    seen[field] = 1
                    order[nfields++] = field
                }
            }
        }
        END {
            for (i = 0; i < nfields; i++) {
                if (i > 0) printf "%s", delim
                printf "%s", order[i]
            }
        }
    ' <<< "$1"
}

cleanup_path_list() {
    # POSIX-shell compatible (sh/dash/bash/zsh): filters delimited path list.
    # Skips leading/trailing/consecutive delims + non-matching items.
    local list="$(unique_list "$1")"
    local test_opt="${2:--d}"
    local delim="${D:-:}"

    local first=1
    while [ -n "$list" ]; do
        item=${list%%${delim}*}
        if [ -n "$item" ] && test $test_opt "$item" 2>/dev/null; then
            if [ "$first" = 1 ]; then
                printf '%s' "$item"
                first=0
            else
                printf '%s%s' "$delim" "$item"
            fi
        fi
        # Advance: strip prefix item + leading delim (if any)
        remainder=${list#"$item"}
        stripped=${remainder#"$delim"}
        if [ "$remainder" = "$stripped" ]; then
            # No leading delim → end of list
            list=""
        else
            list="$stripped"
        fi
    done
}

export PATH="$(cleanup_path_list "$PATH")"
export XDG_DATA_DIRS="$(cleanup_path_list "$XDG_DATA_DIRS")"
export XDG_CONFIG_DIRS="$(cleanup_path_list "$XDG_CONFIG_DIRS")"

[[ -n "${DBG}" ]] && echo "PATH: ${PATH//:/\n}"

