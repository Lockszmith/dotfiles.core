#! /usr/bin/env bash

set -euo pipefail

# 'S: ' prefix means a special file (configuration)
# 'C: ' prefix means a file within the chezmoi source repo
# 'M: ' prefix means a chezmoi managed path
# 'U: ' or no prefix means an unmanaged path
# All paths are assumed to be relative to home, unless it starts with / - which is an absolute path

${SET_X:-:} -x

# echo \
eval "printf '%s\n' $(                          # Build a printf multi-line command so that eval will evaluate managed paths
sed -Ee '
    s|"|\\"|g;                                  # preserve quotes
    s|([S]: )?([^\{]+)( \{[[:alnum:]_ -]+\})|U: \2|;
    s|C: |U: |;
    s|^|U: |; s|^U: ([SCMU]: )|\1|;             # Add U: where type is missing
    s|^([SCUM]: )([^~/"].*)$|~/"\2"|;           # Add quotes (for printf being eval-ed)
    s|^M: (.*)$|\$(cz source-path "\1")|;       # resolve chezmoi managed path
    s|^U: ||;                                   # Remove unmanaged prefix
    s|$| \\|;                                   # passing to printf
'
)" | grep -vE '^\\$'

${SET_X:-:} +x
# vim: set ft=sh sw=4 sts=4 et:

